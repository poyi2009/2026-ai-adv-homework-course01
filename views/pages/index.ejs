<div id="app">
  <!-- Hero Banner -->
  <section class="relative rounded-frame overflow-hidden mb-10">
    <img
      src="https://images.unsplash.com/photo-1689437004653-92d5df41325e?w=1600&q=80"
      alt="花束意象"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-cream via-blush to-rose-primary opacity-[0.62]"></div>
    <div class="relative z-10 flex flex-col items-center text-center gap-5 px-6 py-20 md:py-28">
      <svg class="w-9 h-9 text-berry"><use href="#icon-flower"></use></svg>
      <p class="text-xs font-medium tracking-[0.2em] text-rose-primary uppercase">2026 春季系列</p>
      <h1 class="font-display text-4xl md:text-5xl leading-snug text-text-primary max-w-2xl">
        為日常，留一束詩意
      </h1>
      <p class="text-text-secondary leading-loose max-w-md">
        精選當季花材，手工繫成溫柔心意。
      </p>
      <a href="#products" class="inline-block bg-rose-primary text-white px-8 py-3 rounded-full hover:bg-rose-dark transition-colors text-sm">
        立即選購
      </a>
    </div>
  </section>

  <div class="flex justify-center mb-16 md:mb-20">
    <%- include('../partials/botanical-divider', { dividerClass: 'max-w-md' }) %>
  </div>

  <!-- Featured Products (Asymmetric Masonry) -->
  <section class="mb-16 md:mb-20">
    <div class="text-center mb-8">
      <h2 class="font-display text-2xl md:text-3xl text-text-primary">精選推薦</h2>
      <p class="text-text-muted text-sm mt-2">本季最受歡迎的花卉精選</p>
    </div>
    <div v-if="products.length" class="flex flex-col lg:flex-row gap-5 lg:gap-6">
      <!-- Big column -->
      <div v-if="products[0]" class="lg:flex-1 flex flex-col gap-3.5 cursor-pointer" @click="goToProduct(products[0].id)">
        <div class="rounded-frame overflow-hidden h-[220px] lg:h-[380px]">
          <img
            :src="products[0].image_url || featuredImages[0]"
            :alt="products[0].name"
            class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
          />
        </div>
        <div class="flex items-center justify-between">
          <h3 class="font-medium text-text-primary">{{ products[0].name }}</h3>
          <p class="font-display text-lg text-berry">NT$ {{ products[0].price.toLocaleString() }}</p>
        </div>
      </div>

      <!-- Mid stacked columns -->
      <div class="flex flex-row lg:flex-col gap-4 lg:gap-5 lg:w-[280px] h-[170px] lg:h-[420px]">
        <div
          v-for="p in [products[1], products[2]].filter(Boolean)"
          :key="p.id"
          class="relative flex-1 rounded-card overflow-hidden cursor-pointer"
          @click="goToProduct(p.id)"
        >
          <img :src="p.image_url || featuredImages[1]" :alt="p.name" class="absolute inset-0 w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4 text-white">
            <p class="font-display text-base leading-tight">{{ p.name }}</p>
            <p class="text-sm">NT$ {{ p.price.toLocaleString() }}</p>
          </div>
        </div>
      </div>

      <!-- Right tall column (desktop only) -->
      <div
        v-if="products[3]"
        class="hidden lg:block relative lg:w-[340px] lg:h-[420px] rounded-frame overflow-hidden cursor-pointer"
        @click="goToProduct(products[3].id)"
      >
        <img :src="products[3].image_url || featuredImages[2]" :alt="products[3].name" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 p-5 text-white">
          <p class="font-display text-lg leading-tight">{{ products[3].name }}</p>
          <p class="text-sm">NT$ {{ products[3].price.toLocaleString() }}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Story -->
  <section class="mb-16 md:mb-20 bg-white rounded-frame overflow-hidden shadow-sm">
    <div class="flex flex-col lg:flex-row">
      <div class="lg:w-[480px] shrink-0">
        <img
          src="https://images.unsplash.com/photo-1508610048659-a06b669e3321?w=600"
          alt="花藝師"
          class="w-full h-64 lg:h-full object-cover"
        />
      </div>
      <div class="p-8 lg:p-16 flex flex-col justify-center gap-4">
        <h2 class="font-display text-2xl md:text-3xl text-text-primary">
          專心，做好一束花的感動
        </h2>
        <p class="text-text-secondary leading-loose">
          花漾生活成立於 2020 年，我們相信每一朵花都有自己的故事。透過專業花藝師的巧手，將大自然的美好帶進您的日常生活中。
        </p>
        <p class="font-display text-berry italic">
          「每一束花，都是一份用心的禮物。」
        </p>
      </div>
    </div>
  </section>

  <!-- All Products Grid -->
  <section id="products" class="mb-16 md:mb-20">
    <div class="text-center mb-8">
      <h2 class="font-display text-2xl md:text-3xl text-text-primary">
        探索所有花藝
      </h2>
      <p class="text-text-muted text-sm mt-2">找到屬於您的那束花</p>
    </div>

    <div v-if="loading" class="flex justify-center py-12">
      <div class="w-8 h-8 border-4 border-rose-primary border-t-transparent rounded-full animate-spin"></div>
    </div>

    <template v-else>
      <div v-if="products.length === 0" class="text-center py-12">
        <div class="text-4xl mb-3">&#127804;</div>
        <p class="text-text-secondary">目前沒有商品</p>
        <p class="text-text-muted text-sm">請稍後再來看看</p>
      </div>

      <div v-else class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        <div
          v-for="product in products"
          :key="product.id"
          @click="goToProduct(product.id)"
          class="bg-white rounded-card shadow-sm overflow-hidden cursor-pointer hover:shadow-md transition-shadow group"
        >
          <div class="aspect-square overflow-hidden">
            <img
              :src="product.image_url || 'https://images.unsplash.com/photo-1490750967868-88aa4f44baee?w=400'"
              :alt="product.name"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-5">
            <h3 class="font-medium text-text-primary mb-1 truncate">{{ product.name }}</h3>
            <p class="font-display text-lg text-berry mb-3">NT$ {{ product.price.toLocaleString() }}</p>
            <button
              @click.stop="addToCart(product)"
              :disabled="product._adding || product.stock <= 0"
              class="w-full bg-rose-primary text-white py-2 rounded-full text-sm hover:bg-rose-dark transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            >
              {{ product.stock <= 0 ? '已售完' : '加入購物車' }}
            </button>
          </div>
        </div>
      </div>

      <!-- Pagination -->
      <div v-if="pagination.totalPages > 1" class="flex justify-center gap-2 mt-8">
        <button
          v-for="p in pagination.totalPages"
          :key="p"
          @click="loadProducts(p)"
          class="w-10 h-10 rounded-full text-sm transition-colors"
          :class="p === pagination.page ? 'bg-rose-primary text-white' : 'bg-white text-text-secondary hover:bg-rose-bg'"
        >
          {{ p }}
        </button>
      </div>
    </template>
  </section>

  <!-- Customer Testimonials -->
  <section class="mb-16 md:mb-20">
    <div class="text-center mb-8">
      <h2 class="font-display text-2xl md:text-3xl text-text-primary">
        顧客花束好評分享
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      <div class="bg-white rounded-card p-7 shadow-sm">
        <div class="text-apricot mb-2">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="text-text-secondary text-sm mb-4 leading-relaxed">「花束非常漂亮，包裝精緻，送給媽媽她超開心的！配送也很準時。」</p>
        <p class="text-text-muted text-xs">-- 小美</p>
      </div>
      <div class="bg-white rounded-card p-7 shadow-sm">
        <div class="text-apricot mb-2">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="text-text-secondary text-sm mb-4 leading-relaxed">「第二次購買了，品質一如既往的好。花材新鮮，整體搭配很有美感。」</p>
        <p class="text-text-muted text-xs">-- 阿明</p>
      </div>
      <div class="bg-white rounded-card p-7 shadow-sm">
        <div class="text-apricot mb-2">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="text-text-secondary text-sm mb-4 leading-relaxed">「女朋友收到花束超感動！會再回購的，推薦給大家！」</p>
        <p class="text-text-muted text-xs">-- 大衛</p>
      </div>
    </div>
  </section>

  <!-- Service Features -->
  <section class="mb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 text-center">
      <div class="bg-white rounded-card p-7 shadow-sm flex flex-col items-center gap-2.5">
        <svg class="w-7 h-7 text-rose-primary"><use href="#icon-truck"></use></svg>
        <h3 class="font-medium text-text-primary">快速配送</h3>
        <p class="text-text-muted text-sm">台北市區當日配送</p>
      </div>
      <div class="bg-white rounded-card p-7 shadow-sm flex flex-col items-center gap-2.5">
        <svg class="w-7 h-7 text-rose-primary"><use href="#icon-gift"></use></svg>
        <h3 class="font-medium text-text-primary">精美包裝</h3>
        <p class="text-text-muted text-sm">每束花都經過精心包裝</p>
      </div>
      <div class="bg-white rounded-card p-7 shadow-sm flex flex-col items-center gap-2.5">
        <svg class="w-7 h-7 text-rose-primary"><use href="#icon-heart"></use></svg>
        <h3 class="font-medium text-text-primary">滿額免運</h3>
        <p class="text-text-muted text-sm">消費滿 NT$ 500 免運費</p>
      </div>
    </div>
  </section>
</div>
