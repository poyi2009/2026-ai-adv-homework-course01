<div id="app">
  <h1 class="font-display text-2xl text-text-primary mb-6">我的訂單</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-rose-primary border-t-transparent rounded-full animate-spin"></div>
  </div>

  <div v-else-if="orders.length === 0" class="text-center py-12">
    <div class="text-4xl mb-3">&#128230;</div>
    <p class="text-text-secondary mb-1">尚無訂單</p>
    <p class="text-text-muted text-sm mb-4">快去選購喜歡的花束吧！</p>
    <a href="/" class="inline-block bg-rose-primary text-white px-6 py-2 rounded-full text-sm hover:bg-rose-dark transition-colors">去逛逛</a>
  </div>

  <div v-else class="space-y-4">
    <!-- Desktop row -->
    <a
      v-for="order in orders"
      :key="order.id"
      :href="'/orders/' + order.id"
      class="hidden md:flex items-center justify-between bg-white rounded-card shadow-sm p-6 hover:shadow-md transition-shadow"
    >
      <div>
        <p class="font-display text-base text-text-primary">{{ order.order_no }}</p>
        <p class="text-xs text-text-muted mt-1">{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</p>
      </div>
      <div class="flex items-center gap-5">
        <span class="font-display text-lg text-berry">NT$ {{ order.total_amount.toLocaleString() }}</span>
        <span
          class="text-xs px-3 py-1 rounded-full font-medium"
          :class="statusMap[order.status]?.cls || 'bg-gray-100 text-gray-600'"
        >
          {{ statusMap[order.status]?.label || order.status }}
        </span>
        <svg class="w-[18px] h-[18px] text-text-muted"><use href="#icon-chevron-right"></use></svg>
      </div>
    </a>

    <!-- Mobile card -->
    <a
      v-for="order in orders"
      :key="'m-' + order.id"
      :href="'/orders/' + order.id"
      class="flex md:hidden flex-col gap-2 bg-white rounded-card shadow-sm p-4"
    >
      <div class="flex items-center justify-between">
        <span class="font-display text-sm text-text-primary">{{ order.order_no }}</span>
        <span
          class="text-xs px-2.5 py-1 rounded-full font-medium"
          :class="statusMap[order.status]?.cls || 'bg-gray-100 text-gray-600'"
        >
          {{ statusMap[order.status]?.label || order.status }}
        </span>
      </div>
      <div class="flex items-center justify-between">
        <span class="text-text-muted text-xs">{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</span>
        <span class="font-display text-base text-berry">NT$ {{ order.total_amount.toLocaleString() }}</span>
      </div>
    </a>
  </div>
</div>
