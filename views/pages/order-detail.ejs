<div id="app" data-order-id="<%= orderId %>" data-payment-result="<%= paymentResult %>">
  <h1 class="font-display text-2xl text-text-primary mb-6">訂單詳情</h1>

  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-rose-primary border-t-transparent rounded-full animate-spin"></div>
  </div>

  <template v-else-if="order">
    <!-- Payment Result Alert -->
    <div
      v-if="paymentResult && paymentMessages[paymentResult]"
      class="rounded-card p-5 mb-6 text-sm flex items-center gap-3"
      :class="paymentMessages[paymentResult].cls"
    >
      {{ paymentMessages[paymentResult].text }}
    </div>

    <!-- Info Columns -->
    <div class="flex flex-col lg:flex-row gap-6 mb-6">
      <!-- Order Info -->
      <div class="bg-white rounded-card shadow-sm p-6 flex-1">
        <h2 class="font-display text-base text-text-primary mb-3">訂單資訊</h2>
        <div class="text-sm space-y-2.5">
          <div class="flex justify-between">
            <span class="text-text-muted">訂單編號</span>
            <span class="text-text-primary">{{ order.order_no }}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">訂單日期</span>
            <span class="text-text-primary">{{ new Date(order.created_at).toLocaleDateString('zh-TW') }}</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-text-muted">訂單狀態</span>
            <span
              class="text-xs px-3 py-1 rounded-full font-medium"
              :class="statusMap[order.status]?.cls || 'bg-gray-100 text-gray-600'"
            >
              {{ statusMap[order.status]?.label || order.status }}
            </span>
          </div>
        </div>
      </div>

      <!-- Recipient Info -->
      <div class="bg-white rounded-card shadow-sm p-6 flex-1">
        <h2 class="font-display text-base text-text-primary mb-3">收件資訊</h2>
        <div class="text-sm space-y-2.5">
          <div class="flex justify-between">
            <span class="text-text-muted">收件人</span>
            <span class="text-text-primary">{{ order.recipient_name }}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">Email</span>
            <span class="text-text-primary">{{ order.recipient_email }}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-muted">地址</span>
            <span class="text-text-primary">{{ order.recipient_address }}</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Order Items -->
    <div class="bg-white rounded-card shadow-sm p-6 mb-6">
      <h2 class="font-display text-base text-text-primary mb-3">商品明細</h2>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border-hairline text-text-muted">
            <th class="text-left py-2 font-normal">商品名稱</th>
            <th class="text-right py-2 font-normal">單價</th>
            <th class="text-right py-2 font-normal">數量</th>
            <th class="text-right py-2 font-normal">小計</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="item in order.items" :key="item.id" class="border-b border-border-hairline/60">
            <td class="py-3 text-text-primary">{{ item.product_name }}</td>
            <td class="py-3 text-right text-text-secondary">NT$ {{ item.product_price.toLocaleString() }}</td>
            <td class="py-3 text-right text-text-secondary">{{ item.quantity }}</td>
            <td class="py-3 text-right text-text-primary font-medium">NT$ {{ (item.product_price * item.quantity).toLocaleString() }}</td>
          </tr>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3" class="pt-3 text-right font-medium text-text-primary">總計</td>
            <td class="pt-3 text-right font-display text-berry text-lg">NT$ {{ order.total_amount.toLocaleString() }}</td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- Payment Button -->
    <div v-if="order.status === 'pending'" class="flex gap-4">
      <button
        @click="handlePayWithECPay"
        :disabled="paying"
        class="bg-rose-primary text-white px-8 py-3 rounded-full text-sm font-medium hover:opacity-90 transition-opacity disabled:opacity-50"
      >
        {{ paying ? '跳轉中...' : '前往 ECPay 付款' }}
      </button>
    </div>
  </template>
</div>
