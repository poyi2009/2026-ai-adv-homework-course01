<div id="app">
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="w-full rounded-frame bg-gradient-to-b from-blush to-cream -mx-4 md:mx-0 px-4 py-16 md:py-20 flex flex-col items-center gap-8">
      <%- include('../partials/botanical-divider', { dividerClass: 'max-w-[200px]' }) %>

      <div class="bg-white rounded-card shadow-lg w-full max-w-md p-8">
        <h1 class="font-display text-2xl text-rose-primary text-center mb-6">
          花漾生活
        </h1>

        <!-- Tabs -->
        <div class="flex mb-6 bg-rose-bg rounded-full p-1 gap-1">
          <button
            @click="activeTab = 'login'; errors = {}"
            class="flex-1 py-2 rounded-full text-sm font-medium transition-colors"
            :class="activeTab === 'login' ? 'bg-rose-primary text-white' : 'text-text-secondary hover:bg-white/60'"
          >
            登入
          </button>
          <button
            @click="activeTab = 'register'; errors = {}"
            class="flex-1 py-2 rounded-full text-sm font-medium transition-colors"
            :class="activeTab === 'register' ? 'bg-rose-primary text-white' : 'text-text-secondary hover:bg-white/60'"
          >
            註冊
          </button>
        </div>

        <!-- Login Form -->
        <form v-if="activeTab === 'login'" @submit.prevent="handleLogin" class="space-y-4">
          <div>
            <label class="block text-sm text-text-secondary mb-1">Email</label>
            <input
              v-model="loginForm.email"
              type="email"
              placeholder="請輸入 Email"
              class="w-full border border-border-hairline rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-primary"
              :class="{ 'border-red-400': errors.email }"
            />
            <p v-if="errors.email" class="text-red-500 text-xs mt-1">{{ errors.email }}</p>
          </div>

          <div>
            <label class="block text-sm text-text-secondary mb-1">密碼</label>
            <input
              v-model="loginForm.password"
              type="password"
              placeholder="請輸入密碼"
              class="w-full border border-border-hairline rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-primary"
              :class="{ 'border-red-400': errors.password }"
            />
            <p v-if="errors.password" class="text-red-500 text-xs mt-1">{{ errors.password }}</p>
          </div>

          <button
            type="submit"
            :disabled="submitting"
            class="w-full bg-rose-primary text-white py-3 rounded-full text-sm font-medium hover:bg-rose-dark transition-colors disabled:opacity-50"
          >
            {{ submitting ? '登入中...' : '登入' }}
          </button>
        </form>

        <!-- Register Form -->
        <form v-else @submit.prevent="handleRegister" class="space-y-4">
          <div>
            <label class="block text-sm text-text-secondary mb-1">姓名</label>
            <input
              v-model="registerForm.name"
              type="text"
              placeholder="請輸入姓名"
              class="w-full border border-border-hairline rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-primary"
              :class="{ 'border-red-400': errors.name }"
            />
            <p v-if="errors.name" class="text-red-500 text-xs mt-1">{{ errors.name }}</p>
          </div>

          <div>
            <label class="block text-sm text-text-secondary mb-1">Email</label>
            <input
              v-model="registerForm.email"
              type="email"
              placeholder="請輸入 Email"
              class="w-full border border-border-hairline rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-primary"
              :class="{ 'border-red-400': errors.email }"
            />
            <p v-if="errors.email" class="text-red-500 text-xs mt-1">{{ errors.email }}</p>
          </div>

          <div>
            <label class="block text-sm text-text-secondary mb-1">密碼</label>
            <input
              v-model="registerForm.password"
              type="password"
              placeholder="至少 6 個字元"
              class="w-full border border-border-hairline rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-rose-primary"
              :class="{ 'border-red-400': errors.password }"
            />
            <p v-if="errors.password" class="text-red-500 text-xs mt-1">{{ errors.password }}</p>
          </div>

          <button
            type="submit"
            :disabled="submitting"
            class="w-full bg-rose-primary text-white py-3 rounded-full text-sm font-medium hover:bg-rose-dark transition-colors disabled:opacity-50"
          >
            {{ submitting ? '註冊中...' : '註冊' }}
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
