<header class="sticky top-0 z-50 bg-cream shadow-sm border-b border-border-hairline">
  <div class="relative max-w-7xl mx-auto flex items-center justify-between px-4 md:px-8 lg:px-12 h-16 md:h-20">
    <a href="/" class="text-lg md:text-xl font-display font-medium text-berry">
      花漾生活
    </a>

    <div class="flex items-center gap-4 md:hidden">
      <a href="/cart" class="relative text-text-primary" aria-label="購物車">
        <svg class="w-5 h-5"><use href="#icon-shopping-bag"></use></svg>
        <span
          class="cart-badge absolute -top-2 -right-2 bg-rose-primary text-white text-xs rounded-full w-5 h-5 items-center justify-center"
          style="display: none;"
        ></span>
      </a>
      <button type="button" id="mobile-menu-toggle" class="text-text-primary" aria-label="開啟選單">
        <svg class="w-6 h-6"><use href="#icon-menu"></use></svg>
      </button>
    </div>

    <div
      id="mobile-nav-panel"
      class="flex-col items-center gap-4 py-4 absolute top-full left-0 right-0 bg-cream border-b border-border-hairline shadow-md md:static md:top-auto md:left-auto md:right-auto md:border-0 md:shadow-none md:bg-transparent md:py-0 md:w-auto md:!flex md:flex-row md:items-center md:gap-8 md:justify-end"
      style="display: none;"
    >
      <nav class="flex flex-col items-center gap-4 md:flex-row md:items-center md:gap-8 text-sm text-text-secondary text-center">
        <a href="/" class="hover:text-rose-primary transition-colors">商品列表</a>
        <a href="/cart" class="hover:text-rose-primary transition-colors relative">
          購物車
          <span
            class="cart-badge absolute -top-2 -right-4 bg-rose-primary text-white text-xs rounded-full w-5 h-5 items-center justify-center"
            style="display: none;"
          ></span>
        </a>
        <a id="orders-link" href="/orders" class="hover:text-rose-primary transition-colors" style="display: none;">
          我的訂單
        </a>
      </nav>

      <div id="auth-nav" class="flex flex-col items-center gap-3 md:flex-row md:items-center md:gap-4 text-sm text-center">
        <a href="/login" class="bg-rose-primary text-white px-5 py-2 rounded-full hover:bg-rose-dark transition-colors inline-block text-center">登入</a>
      </div>
    </div>
  </div>
</header>
